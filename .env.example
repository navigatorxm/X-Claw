# XClaw Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Minimum to get started: set ONE of the LLM providers below.
# Everything else is optional.

# ── LLM Providers (pick at least one) ────────────────────────────────────────

# Groq — fastest free cloud option, 6000 tokens/min free tier
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Google Gemini — generous free tier
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# OpenAI — most capable, pay-as-you-go
OPENAI_API_KEY=your_openai_api_key

# OVH AI Endpoints — private cloud, European data residency
OVH_AI_ENDPOINT=https://your-llama-endpoint.endpoints.kepler.ai.cloud.ovh.net
OVH_API_KEY=your_ovh_api_key

# DigitalOcean GenAI — serverless inference, OpenAI-compatible, pay-per-token
# Create a serverless endpoint at: https://cloud.digitalocean.com/gen-ai
# API docs: https://docs.digitalocean.com/products/gen-ai-platform/
# Available models: llama3-8b-instruct, llama3-70b-instruct, llama3.1-405b-instruct,
#                   mixtral-8x7b-instruct, mistral-7b-instruct, codestral-latest, deepseek-r1
DO_AI_ENDPOINT=https://your-agent-endpoint.ondigitalocean.app/v1
DO_API_KEY=your_do_personal_access_token
DO_AI_MODEL=llama3-70b-instruct        # standard tier model
DO_AI_MODEL_FAST=llama3-8b-instruct    # cheap tier model (fast, low cost)
DO_AI_MODEL_PREMIUM=mistral-7b-instruct # premium tier model

# Ollama — 100% local, zero cost, full privacy
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then pull a model: ollama pull llama3.2  (cheap tier)
#                    ollama pull llama3.1:70b  (standard tier)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2              # cheap tier (fast, small)
OLLAMA_MODEL_LARGE=llama3.1:70b   # standard tier (better reasoning)

# ── Interfaces ────────────────────────────────────────────────────────────────

# Telegram bot (optional — chat with XClaw via Telegram)
# Create a bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── GitHub Integration ────────────────────────────────────────────────────────
# Without token: 60 req/hour on public repos (still works for most use cases)
# With token: 5000 req/hour + private repo access
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your regular password)
# Enable at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password       # App Password from myaccount.google.com/apppasswords
SMTP_FROM=XClaw <you@gmail.com>

# IMAP (for reading email — uses same credentials as SMTP above)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── App Config ────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
PORT=8000               # Web interface port

# XClaw Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Minimum to get started: set ONE of the LLM providers below.
# Everything else is optional.

# ── LLM Providers (pick at least one) ────────────────────────────────────────

# Groq — fastest free cloud option, 6000 tokens/min free tier
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Google Gemini — generous free tier
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# OpenAI — most capable, pay-as-you-go
OPENAI_API_KEY=your_openai_api_key

# OVH AI Endpoints — private cloud, European data residency
OVH_AI_ENDPOINT=https://your-llama-endpoint.endpoints.kepler.ai.cloud.ovh.net
OVH_API_KEY=your_ovh_api_key

# Ollama — 100% local, zero cost, full privacy
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then pull a model: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Interfaces ────────────────────────────────────────────────────────────────

# Telegram bot (optional — chat with XClaw via Telegram)
# Create a bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── GitHub Integration ────────────────────────────────────────────────────────
# Without token: 60 req/hour on public repos (still works for most use cases)
# With token: 5000 req/hour + private repo access
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your regular password)
# Enable at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=XClaw <you@gmail.com>

# ── App Config ────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
PORT=8000               # Web interface port

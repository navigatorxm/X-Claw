# XClaw Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── LLM Providers ────────────────────────────────────────────────────────────

# OVH AI Endpoints (primary — local, private, free tier available)
OVH_AI_ENDPOINT=https://your-llama-endpoint.endpoints.kepler.ai.cloud.ovh.net
OVH_API_KEY=your_ovh_api_key

# Groq (first cloud fallback — very fast)
GROQ_API_KEY=your_groq_api_key

# Google Gemini (second cloud fallback)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (last resort)
OPENAI_API_KEY=your_openai_api_key

# ── Interfaces ────────────────────────────────────────────────────────────────

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── App Config ────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
